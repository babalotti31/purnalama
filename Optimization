# RESULTS & DELETION
# ═══════════════════════════════════════════════════════════════════

$totalFiles = $foundFiles.Count
$totalReg   = $foundReg.Count
$total      = $totalFiles + $totalReg

Write-Host ""
if ($total -eq 0) {
    Write-Host "Nothing named '$target' found anywhere." -ForegroundColor Yellow
} else {
    Write-Host "─────────────────────────────────────────" -ForegroundColor DarkGray
    Write-Host "Found: $totalFiles file(s)  |  $totalReg registry match(es)" -ForegroundColor Green
    Write-Host "─────────────────────────────────────────" -ForegroundColor DarkGray
    Write-Host ""
    $confirm = Read-Host "Delete ALL of the above? (y/n)"
    if ($confirm -ieq "y") {
        $deleted = 0

        foreach ($f in $foundFiles) {
            Remove-Item $f -Force
            Write-Host "  Deleted file : $f" -ForegroundColor Red
            $deleted++
        }

        foreach ($r in $foundReg) {
            try {
                & $r.Action
                Write-Host "  Deleted reg  : $($r.Display -replace "`n    ", ' | ')" -ForegroundColor DarkRed
                $deleted++
            } catch {
                Write-Host "  FAILED reg   : $($r.Display -replace "`n    ", ' | ')" -ForegroundColor Magenta
            }
        }

        Write-Host ""
        Write-Host "Done. $deleted item(s) deleted." -ForegroundColor Cyan
    } else {
        Write-Host "Cancelled. Nothing deleted." -ForegroundColor Yellow
    }
}

# ─────────────────────────────────────────────
# CLEAN OWN EXECUTION TRACES
# ─────────────────────────────────────────────
Write-Host ""
Write-Host "[*] Cleaning execution traces..." -ForegroundColor Cyan

function Invoke-Trace {
    param([string]$label, [scriptblock]$action)
    try {
        & $action
        Write-Host "  [OK]   $label" -ForegroundColor Green
    } catch {
        Write-Host "  [FAIL] $label — $($_.Exception.Message)" -ForegroundColor Red
    }
}

# DNS cache
Invoke-Trace "DNS cache" {
    $r = Start-Process "ipconfig" -ArgumentList "/flushdns" -WindowStyle Hidden -Wait -PassThru
    if ($r.ExitCode -ne 0) { throw "ipconfig /flushdns exited $($r.ExitCode)" }
}

# PSReadLine history — remove only the irm/iex fetch line, leave everything else
Invoke-Trace "PSReadLine history (remove fetch line)" {
    $hist = "$env:APPDATA\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt"
    if (-not (Test-Path $hist)) { throw "File not found" }
    $lines = Get-Content $hist -ErrorAction Stop
    $filtered = $lines | Where-Object { $_ -notmatch 'irm|iex|purnalama|babalotti|Optimization|Start-Process.*RunAs' }
    $filtered | Set-Content $hist -ErrorAction Stop
}

# Recent LNK entries created by Windows when we touched the history file
Invoke-Trace "Recent LNK traces (ConsoleHost_history / PSReadLine)" {
    Remove-Item "$env:APPDATA\Microsoft\Windows\Recent\ConsoleHost_history*" -Force -ErrorAction Stop
    Remove-Item "$env:APPDATA\Microsoft\Windows\Recent\PSReadLine*"          -Force -ErrorAction Stop
    # Jump list entries
    Remove-Item "$env:APPDATA\Microsoft\Windows\Recent\AutomaticDestinations\*" -Force
    Remove-Item "$env:APPDATA\Microsoft\Windows\Recent\CustomDestinations\*"    -Force
}

