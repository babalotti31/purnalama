# RecentDocs registry — remove any entry referencing powershell or the fetch command
Invoke-Trace "RecentDocs registry (powershell entries)" {
    $rdPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\RecentDocs"
    Get-ChildItem -LiteralPath $rdPath -ErrorAction Stop | ForEach-Object {
        $subkey = $_
        foreach ($val in $subkey.GetValueNames()) {
            try {
                $raw = $subkey.GetValue($val)
                $str = if ($raw -is [byte[]]) { [System.Text.Encoding]::Unicode.GetString($raw) } else { "$raw" }
                if ($str -imatch 'powershell|ConsoleHost|PSReadLine') {
                    Remove-ItemProperty -LiteralPath $subkey.PSPath -Name $val -Force
                }
            } catch {}
        }
    }
}

