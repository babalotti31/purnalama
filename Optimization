# Pre-expand, validate, and deduplicate directories
$validDirs = [System.Collections.Generic.List[PSCustomObject]]::new()
$seenExp   = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)
foreach ($raw in $fsDirs) {
    $exp = [System.Environment]::ExpandEnvironmentVariables($raw)
    if ((Test-Path $exp -PathType Container) -and $seenExp.Add($exp)) {
        # C:\ searched shallow only (depth 0) — recursing the full drive takes forever
        $validDirs.Add([PSCustomObject]@{ Path = $exp; Shallow = ($exp -ieq "C:\") })
    }
}

Write-Host "[FILE SYSTEM] Searching $($validDirs.Count) locations in parallel..." -ForegroundColor Cyan

$pool = [System.Management.Automation.Runspaces.RunspaceFactory]::CreateRunspacePool(1, [Environment]::ProcessorCount)
$pool.Open()

$searchScript = {
    param($dir, $target, $shallow)
    $p = @{ Path = $dir; Force = $true; File = $true; ErrorAction = 'SilentlyContinue' }
    if ($shallow) { $p.Depth = 0 } else { $p.Recurse = $true }
    # Match exact BaseName OR first segment before a dot (catches LNK files like "target.exe.lnk")
    Get-ChildItem @p | Where-Object {
        $_.BaseName -ieq $target -or ($_.BaseName -split '\.')[0] -ieq $target
    } | Select-Object -ExpandProperty FullName
}

$jobs = [System.Collections.Generic.List[PSCustomObject]]::new()
foreach ($entry in $validDirs) {
    $ps = [System.Management.Automation.PowerShell]::Create()
    $ps.RunspacePool = $pool
    [void]$ps.AddScript($searchScript).AddArgument($entry.Path).AddArgument($target).AddArgument($entry.Shallow)
    $jobs.Add([PSCustomObject]@{ PS = $ps; Handle = $ps.BeginInvoke(); Dir = $entry.Path; Done = $false })
}

$fsTotal = $jobs.Count
while ($true) {
    $fsDone = ($jobs | Where-Object { $_.Done }).Count
    $pct    = if ($fsTotal -gt 0) { [int](($fsDone / $fsTotal) * 100) } else { 100 }
    Write-Progress -Activity "Scanning file system" -Status "$fsDone / $fsTotal locations done  ($pct%)" -PercentComplete $pct

    foreach ($job in $jobs) {
        if ($job.Done -or -not $job.Handle.IsCompleted) { continue }
        $results = $job.PS.EndInvoke($job.Handle)
        $job.PS.Dispose()
        $job.Done = $true
        foreach ($path in $results) {
            if ($foundFileSet.Add($path)) {
                $foundFiles.Add($path)
                Write-Host "  FILE: $path" -ForegroundColor Gray
            }
        }
    }

    if (($jobs | Where-Object { -not $_.Done }).Count -eq 0) { break }
    Start-Sleep -Milliseconds 150
}
Write-Progress -Activity "Scanning file system" -Completed
