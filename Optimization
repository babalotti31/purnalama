$visitedRegPaths = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)

function Convert-RegPath($path) {
    $path = $path -replace '^HKLM\\', 'HKLM:\' `
                  -replace '^HKCU\\', 'HKCU:\' `
                  -replace '^HKCR\\', 'HKCR:\' `
                  -replace '^HKCC\\', 'HKCC:\'
    return $path
}

function Search-RegKey {
    param([string]$psPath, [string]$pattern, [int]$depth = 3)
    if (-not $visitedRegPaths.Add($psPath)) { return }
    if (-not (Test-Path $psPath)) { return }

    try {
        $key = Get-Item -LiteralPath $psPath -ErrorAction Stop

        # Check each value at this key
        foreach ($valName in $key.GetValueNames()) {
            $matched = $false
            $display = ""
            $act = $null

            # Match on value NAME
            if ($valName -imatch $pattern) {
                $display = "REG VALUE NAME match`n    Key : $psPath`n    Val : $valName"
                $n = $valName
                $p = $psPath
                $act = { Remove-ItemProperty -LiteralPath $p -Name $n -Force }.GetNewClosure()
                $matched = $true
            }

            # Match on value DATA — strings AND binary decoded as UTF-16LE
            # RecentDocs, MUICache etc. store filenames as REG_BINARY in UTF-16LE
            if (-not $matched) {
                try {
                    $raw = $key.GetValue($valName)
                    $str = switch ($raw) {
                        { $_ -is [string]   } { $raw }
                        { $_ -is [string[]] } { $raw -join ' ' }
                        { $_ -is [byte[]]   } { [System.Text.Encoding]::Unicode.GetString($_) }
                        default               { "" }
                    }
                    if ($str -imatch $pattern) {
                        $display = "REG VALUE DATA match`n    Key : $psPath`n    Val : $valName`n    Data: $str"
                        $n = $valName; $p = $psPath
                        $act = { Remove-ItemProperty -LiteralPath $p -Name $n -Force }.GetNewClosure()
                        $matched = $true
                    }
                } catch {}
            }

            if ($matched) {
                $dedupKey = "$psPath|$valName"
                if ($script:foundRegKeys.Add($dedupKey)) {
                    $foundReg.Add([PSCustomObject]@{ Display = $display; Action = $act })
                    Write-Host "  REG : $display" -ForegroundColor DarkYellow
                }
            }
        }

        # Check subkey names
        if ($depth -gt 0) {
            Get-ChildItem -LiteralPath $psPath -ErrorAction Stop | ForEach-Object {
                $child = $_
                if ($child.PSChildName -imatch $pattern) {
                    $cp = $child.PSPath
                    $display = "REG SUBKEY NAME match`n    Key : $($child.PSPath)"
                    $dedupKey = "SUBKEY|$cp"
                    if ($script:foundRegKeys.Add($dedupKey)) {
                        $act = { Remove-Item -LiteralPath $cp -Recurse -Force }.GetNewClosure()
                        $foundReg.Add([PSCustomObject]@{ Display = $display; Action = $act })
                        Write-Host "  REG : $display" -ForegroundColor DarkYellow
                    }
                }
                Search-RegKey -psPath $child.PSPath -pattern $pattern -depth ($depth - 1)
            }
        }
    } catch {}
}

